# Dependency directories (Folder ທີ່ເກັບ Library ຫ້າມເອົາຂຶ້ນເພາະມັນໜັກ)
node_modules/
jspm_packages/

# Env files (ຂໍ້ມູນຄວາມລັບ: Admin Key, DB URL, JWT Secret)
# 🛑 ອັນນີ້ສຳຄັນທີ່ສຸດ ຫ້າມລຶບບັນທັດນີ້ເດັດຂາດ!
.env
.env.test
.env.production

# Logs (ໄຟລ໌ບັນທຶກ Error ຕ່າງໆ)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# OS Cache (ໄຟລ໌ຂີ້ເຫຍື້ອຂອງລະບົບປະຕິບັດການ)
.DS_Store
Thumbs.db

# IDEs and editors (ໄຟລ໌ການຕັ້ງຄ່າຂອງ VS Code)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?